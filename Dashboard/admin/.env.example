# Base URL of the TrashCam detection service (Model/detect_api.py).
# Used by the "Report Trash" page to run garbage detection on uploaded photos.
# For local development this defaults to http://localhost:5000 if unset.
NEXT_PUBLIC_DETECT_API_URL=http://localhost:5000

# Optional: Gemini API key used by the driver chatbot.
# GEMINI_API=your_key_here
